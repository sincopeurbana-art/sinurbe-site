---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import HeroFullscreen from "../components/HeroFullscreen.astro";
import WhatsappButton from "../components/WhatsappButton.astro";
import SocialLinks from "../components/SocialLinks.astro";
import Footer from "../components/Footer.astro";

const slides = [
  { image: "/fotos/pateo-avenidas/area-gourmet-piscina-noite.png" },
  { image: "/fotos/pateo-loures/vista-piscina-cobertura.png" },
  { image: "/fotos/pateo-belem/area-piscina-por-do-sol.png" },
];

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "";
---

<Base
  title="Contacto — SINURBE"
  description="Falar com a equipa SINURBE. Lista de interessados, visitas a empreendimentos ou apenas saber mais. Respondemos em 24 horas em dias úteis."
>
  <Nav overHero={true} pathname={Astro.url.pathname} />

  <HeroFullscreen slides={slides} height="80vh">
    <div class="hero-fs-eyebrow">// 04 — Falar connosco</div>
    <h1 class="hero-fs-title">
      Encontre o seu<br>
      lugar <strong>em Lisboa</strong>.
    </h1>
    <p class="hero-fs-sub">
      Lista de interessados, visitas a empreendimentos, ou apenas saber mais.
      Respondemos em 24 horas em dias úteis.
    </p>
  </HeroFullscreen>

  <section class="contact-sec">
    <div class="container contact-grid">
      <!-- Coluna esquerda: contactos -->
      <div>
        <div class="section-label">Departamento Comercial</div>
        <h2 class="h3">Atendimento<br>personalizado.</h2>

        <div class="contact-list">
          <div class="contact-row">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--telha)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <div class="contact-label">Email</div>
              <a href="mailto:comercial@sinurbe.pt" class="contact-value highlight">comercial@sinurbe.pt</a>
            </div>
          </div>

          <div class="contact-row">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--telha)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <div class="contact-label">Telemóvel</div>
              <a href="tel:+351924184141" class="contact-value highlight">+351 924 184 141</a>
            </div>
          </div>

          <div class="contact-row">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--telha)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <div class="contact-label">Atelier</div>
              <div class="contact-value">Av. da Liberdade 224, 2.º<br>1250-148 Lisboa</div>
            </div>
          </div>

          <div class="contact-row">
            <div class="contact-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--telha)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div>
              <div class="contact-label">Horário</div>
              <div class="contact-value">Segunda a Sexta<br>9h30 — 18h30</div>
            </div>
          </div>
        </div>

        <div class="separator">
          <div class="section-label" style="margin-bottom:12px;">Mais rápido</div>
          <WhatsappButton variant="lg" label="Falar agora no WhatsApp" />
        </div>

        <div class="separator">
          <div class="section-label" style="margin-bottom:14px;">Siga-nos</div>
          <SocialLinks variant="light" />
        </div>
      </div>

      <!-- Coluna direita: form -->
      <aside class="form-card">
        <div class="section-label" style="margin-bottom:8px;">Mensagem por email</div>
        <h3 class="form-title">Enviar mensagem</h3>

        <form action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="[Site SINURBE] Pedido geral" />
          <input type="hidden" name="from_name" value="Site SINURBE" />
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="form-field">
            <label>Nome</label>
            <input type="text" name="nome" required placeholder="O seu nome" />
          </div>
          <div class="form-field">
            <label>Email</label>
            <input type="email" name="email" required placeholder="email@exemplo.pt" />
          </div>
          <div class="form-field">
            <label>Telemóvel <span class="optional">opcional</span></label>
            <input type="tel" name="telemovel" placeholder="+351 9XX XXX XXX" />
          </div>
          <div class="form-field">
            <label>Interesse</label>
            <select name="interesse">
              <option>Lista de interessados (todos os empreendimentos)</option>
              <option>Páteo Gastão (Beato)</option>
              <option>Páteo Belém</option>
              <option>Páteo Estrela</option>
              <option>Páteo Loures</option>
              <option>Páteo Avenidas</option>
              <option>Páteo Bento (São Bento)</option>
            </select>
          </div>
          <div class="form-field">
            <label>Mensagem <span class="optional">opcional</span></label>
            <textarea name="mensagem" rows="4" placeholder="Conte-nos o que procura — bairro, área, prazo."></textarea>
          </div>
          <button type="submit" class="btn-submit">Entrar em contacto</button>
        </form>

        <p class="privacy">
          Os seus dados ficam connosco. Não partilhamos com terceiros.
        </p>
      </aside>
    </div>
  </section>

  <Footer />
</Base>

<style>
  :global(.hero-fs-sub) {
    color: rgba(255,255,255,0.9);
    font-size: 17px;
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: 0;
    font-weight: 300;
    text-shadow: 0 2px 16px rgba(0,0,0,0.4);
  }

  .contact-sec { padding: 72px 0 96px; }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 80px;
    align-items: start;
    max-width: 1100px;
  }

  .h3 {
    font-family: var(--font-display);
    font-size: 32px;
    margin: 12px 0 32px;
    letter-spacing: -0.5px;
    line-height: 1.05;
  }

  .contact-list { display: flex; flex-direction: column; gap: 24px; }
  .contact-row {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }
  .contact-icon {
    flex-shrink: 0;
    width: 44px; height: 44px;
    background: rgba(184, 68, 46, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact-icon svg { width: 20px; height: 20px; }
  .contact-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--cinza);
    margin-bottom: 4px;
  }
  .contact-value {
    font-size: 16px;
    color: var(--preto);
    line-height: 1.4;
    text-decoration: none;
  }
  .contact-value.highlight { color: var(--telha); font-weight: 600; font-size: 17px; }

  .separator {
    padding-top: 32px;
    margin-top: 24px;
    border-top: 1px solid rgba(26,26,26,0.1);
  }

  .form-card {
    background: var(--branco);
    border: 1px solid rgba(26, 26, 26, 0.1);
    border-radius: 4px;
    padding: 40px 36px;
  }
  .form-title {
    font-family: var(--font-display);
    font-size: 24px;
    margin-bottom: 24px;
    letter-spacing: -0.3px;
  }

  .form-field { display: block; margin-bottom: 12px; }
  .form-field label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--cinza);
    margin-bottom: 6px;
  }
  .form-field .optional { text-transform: none; color: var(--cinza); }
  .form-field input,
  .form-field select,
  .form-field textarea {
    width: 100%;
    padding: 10px 12px;
    font-family: var(--font-body);
    font-size: 14px;
    border: 1px solid rgba(26,26,26,0.2);
    border-radius: 3px;
    background: var(--creme);
    color: var(--preto);
    box-sizing: border-box;
    transition: border-color 0.2s;
  }
  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--telha);
  }
  .form-field textarea { resize: vertical; min-height: 88px; }

  .btn-submit {
    display: block;
    width: 100%;
    padding: 14px;
    background: var(--preto);
    color: var(--creme);
    border: none;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-top: 8px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-submit:hover { background: var(--telha); }

  .privacy {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: var(--cinza);
    line-height: 1.5;
    margin-top: 12px;
    letter-spacing: 0.3px;
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 48px; }
    .form-card { padding: 28px 24px; }
  }
</style>
