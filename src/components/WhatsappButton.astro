---
/**
 * Botão WhatsApp com mensagem pré-preenchida.
 * Variante "default" — botão verde compacto.
 * Variante "lg" — botão grande com sombra (página de contacto).
 */
export interface Props {
  empName?: string;
  variant?: "default" | "lg";
  label?: string;
}
const {
  empName,
  variant = "default",
  label = "WhatsApp comercial",
} = Astro.props;

const number = "351924184141";
const msg = empName
  ? `Olá! Gostaria de saber mais sobre o empreendimento ${empName}.`
  : "Olá, vinha pelo site SINURBE.";
const url = `https://wa.me/${number}?text=${encodeURIComponent(msg)}`;
---

<a
  class={variant === "lg" ? "btn-wa-lg" : "btn-wa"}
  href={url}
  target="_blank"
  rel="noopener"
>
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path d="M17.5 14.4c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1s-.8.9-1 1.1c-.2.2-.4.2-.6.1-.3-.1-1.1-.4-2.2-1.3-.8-.7-1.3-1.6-1.5-1.9-.2-.3 0-.4.1-.5.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1.1 1-1.1 2.5s1.1 2.9 1.2 3.1c.1.2 2.2 3.4 5.4 4.7.7.3 1.3.5 1.8.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4-.1-.1-.3-.2-.5-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 4.9L2 22l5.2-1.3c1.4.7 2.9 1.1 4.5 1.1h.3c5.5 0 10-4.5 10-10S17.5 2 12 2z"/>
  </svg>
  {label}
</a>

<style>
  .btn-wa, .btn-wa-lg {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    font-family: var(--font-body);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
    border: none;
  }
  .btn-wa {
    width: 100%;
    padding: 13px;
    font-size: 14px;
    letter-spacing: 0.3px;
    margin-top: 8px;
  }
  .btn-wa svg { width: 26px; height: 26px; fill: currentColor; }
  .btn-wa:hover { background: #1FAD52; }

  .btn-wa-lg {
    padding: 18px 32px;
    font-size: 17px;
    letter-spacing: 0.3px;
    border-radius: 4px;
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.3);
    gap: 14px;
  }
  .btn-wa-lg svg { width: 34px; height: 34px; fill: currentColor; }
  .btn-wa-lg:hover { background: #1FAD52; transform: translateY(-2px); }
</style>
