---

<div class={`social-links ${variant === "light" ? "social-light" : ""}`}>
  {socials.map((s) => (
    <a href={s.url} target="_blank" rel="noopener" aria-label={s.name}>
      <svg viewBox="0 0 24 24"><path d={s.path} /></svg>
    </a>
  ))}
</div>

<style>
  .social-links {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .social-links a {
    width: 36px; height: 36px;
    border: 1px solid rgba(245, 241, 234, 0.2);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(245, 241, 234, 0.75);
    transition: all 0.2s;
  }
  .social-links a:hover {
    background: var(--telha);
    border-color: var(--telha);
    color: var(--creme);
    transform: translateY(-2px);
  }
  .social-links svg { width: 16px; height: 16px; fill: currentColor; }

  /* Variante clara (sobre fundo creme) */
  .social-light a {
    background: rgba(184, 68, 46, 0.08);
    border-color: rgba(184, 68, 46, 0.15);
    color: var(--telha);
  }
  .social-light a:hover {
    background: var(--telha);
    border-color: var(--telha);
    color: var(--creme);
  }
</style>
