---
// Formulário de contacto Web3Forms — focado em lista de interessados / agendar visita
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "DEMO_KEY_SUBSTITUIR";
---
<section id="contacto" class="contact">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <span class="eyebrow">// 04 — Falar connosco</span>
        <h2 class="h2">Encontre o seu lugar <span style="color:var(--accent)">em Lisboa</span>.</h2>
        <p class="lead">Lista de interessados, visitas a empreendimentos, ou apenas saber mais.
          Respondemos em 24 horas em dias úteis.</p>

        <div class="contact-list">
          <div class="row"><span class="label">Email</span><a href="mailto:eduardo@sinurbe.pt">eduardo@sinurbe.pt</a></div>
          <div class="row"><span class="label">Telemóvel</span><a href="tel:+351924184141">+351 924 184 141</a></div>
          <div class="row"><span class="label">Atelier</span><span>Av. da Liberdade 224, 2º · Lisboa</span></div>
          <div class="row"><span class="label">Horário</span><span>Seg–Sex · 9h30–18h30</span></div>
        </div>
      </div>

      <form class="form-card" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="Novo interessado via sinurbe.pt" />
        <input type="hidden" name="from_name" value="SINURBE · sinurbe.pt" />
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

        <label for="nome">Nome</label>
        <input id="nome" name="nome" type="text" placeholder="O seu nome" required />

        <label for="email">Email</label>
        <input id="email" name="email" type="email" placeholder="email@exemplo.pt" required />

        <label for="tel">Telemóvel <span class="opt">opcional</span></label>
        <input id="tel" name="telemovel" type="tel" placeholder="+351 9XX XXX XXX" />

        <label for="interesse">Interesse</label>
        <select id="interesse" name="interesse">
          <option>Lista de interessados (todos os empreendimentos)</option>
          <option>Visita a empreendimento específico</option>
          <option>Informação sobre tipologia / preço</option>
          <option>Outro</option>
        </select>

        <label for="tipologia">Tipologia procurada <span class="opt">opcional</span></label>
        <select id="tipologia" name="tipologia">
          <option value="">Indiferente</option>
          <option>T0 · Studio</option>
          <option>T1</option>
          <option>T2</option>
          <option>T3</option>
          <option>T4+</option>
        </select>

        <label for="msg">Mensagem <span class="opt">opcional</span></label>
        <textarea id="msg" name="mensagem" placeholder="Conte-nos o que procura — bairro, área, prazo."></textarea>

        <button type="submit" class="btn">Entrar em contacto</button>
        <p class="form-note">Os seus dados ficam connosco. Não partilhamos com terceiros.</p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact { background: var(--bg-deep); padding: 110px 0; border-top: 1px solid var(--line); }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 70px;
    align-items: start;
  }
  @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; gap: 50px; } }

  .contact-info .h2 { margin-top: 18px; margin-bottom: 24px; }
  .contact-info p.lead { margin-bottom: 36px; max-width: 46ch; }

  .contact-list { font-family: var(--font-mono); font-size: 0.95rem; color: var(--ink-soft); }
  .contact-list .row {
    display: flex;
    gap: 14px;
    padding: 14px 0;
    border-top: 1px solid var(--line);
    align-items: baseline;
  }
  .contact-list .row:last-child { border-bottom: 1px solid var(--line); }
  .contact-list .label {
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    min-width: 90px;
  }
  .contact-list a:hover { color: var(--accent); }

  .form-card {
    background: var(--bg);
    padding: 36px;
    border-radius: 6px;
    border: 1px solid var(--line);
  }
  .form-card label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
    margin-top: 18px;
  }
  .form-card label:first-of-type { margin-top: 0; }
  .form-card label .opt {
    font-family: var(--font-body);
    text-transform: none;
    letter-spacing: 0;
    color: var(--muted);
    font-size: 0.66rem;
    margin-left: 4px;
    opacity: 0.7;
  }
  .form-card input, .form-card textarea, .form-card select {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--line);
    background: var(--bg);
    font-family: var(--font-body);
    font-size: 0.96rem;
    color: var(--ink);
    border-radius: 4px;
    transition: border-color 0.2s;
  }
  .form-card input:focus, .form-card textarea:focus, .form-card select:focus {
    outline: none;
    border-color: var(--accent);
  }
  .form-card textarea { min-height: 100px; resize: vertical; }

  .btn {
    margin-top: 26px;
    background: var(--ink);
    color: var(--bg);
    padding: 14px 28px;
    border-radius: 999px;
    border: none;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.96rem;
    cursor: pointer;
    transition: background 0.2s;
    width: 100%;
  }
  .btn:hover { background: var(--accent); }

  .form-note {
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-align: center;
  }
</style>
