---
const steps = [
  { n: "01", t: "Visita & briefing",     d: "Visitamos o imóvel, ouvimos o que pretende e devolvemos uma estimativa de viabilidade em 7 dias." },
  { n: "02", t: "Estudo prévio",         d: "Levantamento, propostas de intervenção e orçamento por capítulos. Documento entregável e independente." },
  { n: "03", t: "Projeto & licenciamento", d: "Arquitetura + especialidades + CML. Conduzimos o licenciamento ponta a ponta." },
  { n: "04", t: "Obra & entrega",        d: "Direção de obra e fiscalização própria. Entrega chave-na-mão com livro de obra digital." },
];
---
<section id="processo" class="process">
  <div class="container">
    <div class="section-head">
      <div class="left">
        <span class="eyebrow">// 04 — Como trabalhamos</span>
        <h2 class="h2">Quatro etapas. Sem surpresas.</h2>
        <p class="lead">Trabalhamos por marcos definidos. Em cada um, decide se continua — sem custos escondidos para a fase seguinte.</p>
      </div>
    </div>

    <div class="steps">
      {steps.map(s => (
        <div class="step">
          <div class="num">{s.n}</div>
          <h3>{s.t}</h3>
          <p>{s.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    background: var(--ink);
    color: var(--bg);
    padding: 100px 0;
    border-top: 1px solid var(--line);
  }
  .process .eyebrow { color: var(--accent); }
  .process h2 { color: var(--bg); }
  .process p.lead { color: rgba(245,241,234,.7); }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 60px;
    flex-wrap: wrap;
  }
  .section-head .left { max-width: 680px; }
  .section-head h2 { margin-top: 14px; }

  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,.08);
    margin-top: 60px;
  }
  @media (max-width: 900px) { .steps { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .steps { grid-template-columns: 1fr; } }

  .step { background: var(--ink); padding: 32px 24px; }
  .step .num {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--accent);
    line-height: 1;
  }
  .step h3 {
    margin: 14px 0 8px;
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1rem;
    letter-spacing: -0.01em;
  }
  .step p { color: rgba(245,241,234,.7); font-size: 0.92rem; }
</style>
