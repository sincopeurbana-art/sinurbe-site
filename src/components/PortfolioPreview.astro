---
// Empreendimentos em destaque na home (3 cards estilo "capítulo" magazine).
// Fase 2 — quando o Notion estiver ligado, passa empreendimentos 'Destacar na home?' aqui.
export interface EmpreendimentoCard {
  slug: string;
  nome: string;
  bairro: string;
  estado: string;            // "Em lançamento" | "Em construção" | "Disponível" | "Esgotado"
  descricaoCurta: string;
  capa: string;
  tipologias?: string;       // "T1 · T2 · T3"
  precoDesde?: number;       // em €
  ano?: number;
}

const { empreendimentos = [] as EmpreendimentoCard[] } = Astro.props;

// Fallback enquanto não há dados reais
const fallback: EmpreendimentoCard[] = empreendimentos.length > 0 ? empreendimentos : [
  {
    slug: "edificio-chiado",
    nome: "Edifício no Chiado",
    bairro: "Chiado",
    estado: "Em lançamento",
    descricaoCurta: "Pombalino reabilitado. Frações desenhadas para viver o centro histórico.",
    capa: "https://images.unsplash.com/photo-1568605114967-8130f3a36994?w=1600&q=80&fit=crop&auto=format",
    tipologias: "T1 · T2 · T3",
    precoDesde: 485000,
  },
  {
    slug: "edificio-beato",
    nome: "Edifício no Beato",
    bairro: "Beato",
    estado: "Em construção",
    descricaoCurta: "Reconversão de armazém industrial. Pés-direitos altos, luz nascente.",
    capa: "https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?w=1600&q=80&fit=crop&auto=format",
    tipologias: "T2 · T3 · T4",
    precoDesde: 395000,
    ano: 2027,
  },
  {
    slug: "em-prospecao",
    nome: "Mais empreendimentos a caminho",
    bairro: "Lisboa",
    estado: "Em prospeção",
    descricaoCurta: "Estamos a fechar 3 edifícios em Príncipe Real, Estrela e Alfama. Entrar na lista de interessados.",
    capa: "https://images.unsplash.com/photo-1597092474812-3ea1f48ba74e?w=1600&q=80&fit=crop&auto=format",
  },
];

function formatPreco(n?: number) {
  if (!n) return null;
  return new Intl.NumberFormat('pt-PT', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);
}
---
<section id="empreendimentos-destaque">
  <div class="container">
    <div class="section-head">
      <div class="left">
        <span class="eyebrow">// 03 — Em destaque</span>
        <h2 class="h2">Empreendimentos atuais.</h2>
        <p class="lead-sub">Em lançamento, em construção, em prospeção. Os edifícios em que estamos hoje.</p>
      </div>
      <a class="ver-todos" href="/empreendimentos">Catálogo completo →</a>
    </div>

    <div class="empreendimentos-grid">
      {fallback.map((p, i) => (
        <a href={`/empreendimentos/${p.slug}`} class={`empreendimento ${i === 0 ? 'is-feature' : ''}`}>
          <div class="img" style={`background-image:url('${p.capa}')`}>
            <span class={`badge badge-${p.estado.toLowerCase().replace(/\s+/g, '-').replace(/[ãç]/g, c => c === 'ã' ? 'a' : 'c')}`}>{p.estado}</span>
          </div>
          <div class="info">
            <div class="loc">{p.bairro}</div>
            <h3>{p.nome}</h3>
            <p>{p.descricaoCurta}</p>
            <div class="meta">
              {p.tipologias && <span class="meta-pill">{p.tipologias}</span>}
              {p.precoDesde && <span class="meta-preco">Desde <strong>{formatPreco(p.precoDesde)}</strong></span>}
              {p.ano && !p.precoDesde && <span class="meta-preco">Conclusão <strong>{p.ano}</strong></span>}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  section { padding: 110px 0; border-top: 1px solid var(--line); }
  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    margin-bottom: 56px;
    flex-wrap: wrap;
  }
  .section-head .left { max-width: 680px; }
  .section-head h2 { margin-top: 16px; }
  .lead-sub { margin-top: 18px; color: var(--ink-soft); font-size: 1.08rem; }
  .ver-todos {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 4px;
    white-space: nowrap;
  }
  .ver-todos:hover { color: var(--accent-dark); border-color: var(--accent-dark); }

  .empreendimentos-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    grid-auto-rows: 1fr;
    gap: 22px;
  }
  @media (max-width: 1000px) {
    .empreendimentos-grid { grid-template-columns: 1fr 1fr; }
    .empreendimento.is-feature { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .empreendimentos-grid { grid-template-columns: 1fr; }
    .empreendimento.is-feature { grid-column: auto; }
  }

  .empreendimento {
    background: var(--bg);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--line);
    transition: transform .25s ease, box-shadow .25s ease;
    display: flex;
    flex-direction: column;
    color: inherit;
  }
  .empreendimento:hover { transform: translateY(-4px); box-shadow: 0 24px 50px -25px rgba(26,26,26,.3); }

  .img {
    position: relative;
    aspect-ratio: 4/3;
    background-color: #a88f6b;
    background-size: cover;
    background-position: center;
    transition: transform .6s ease;
  }
  .empreendimento.is-feature .img { aspect-ratio: 5/4; }
  .empreendimento:hover .img { transform: scale(1.03); }
  .img::before {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 55%, rgba(0,0,0,.45) 100%);
  }
  .badge {
    position: absolute; top: 14px; left: 14px;
    background: var(--bg); color: var(--ink);
    font-family: var(--font-mono); font-size: 0.65rem;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 5px 11px; border-radius: 999px;
    z-index: 1;
  }
  .badge.badge-em-lancamento { background: var(--accent); color: var(--bg); }
  .badge.badge-em-construcao { background: var(--ink); color: var(--bg); }
  .badge.badge-em-prospecao { background: transparent; color: var(--bg); border: 1px solid rgba(255,255,255,.6); }
  .badge.badge-esgotado { background: var(--muted); color: var(--bg); opacity: 0.7; }

  .info { padding: 24px 24px 28px; display: flex; flex-direction: column; gap: 10px; flex-grow: 1; }
  .info .loc {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .info h3 {
    margin: 4px 0 4px;
    font-family: var(--font-display);
    font-size: 1.22rem;
    text-transform: uppercase;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }
  .empreendimento.is-feature .info h3 { font-size: 1.5rem; }
  .info p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
    flex-grow: 1;
  }
  .meta {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }
  .meta-pill {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--ink-soft);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    background: var(--bg-deep);
    border-radius: 999px;
  }
  .meta-preco {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .meta-preco strong {
    color: var(--ink);
    font-weight: 600;
    letter-spacing: 0.01em;
  }
</style>
