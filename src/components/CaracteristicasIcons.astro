---
/**
 * Renderiza um grid de características em ícones (estilo Lucide).
 * Cada item tem um `icon` (chave abaixo) e `label`.
 */
export interface Item {
  icon: string;
  label: string;
}
export interface Props {
  items: Item[];
}
const { items } = Astro.props;

// Cada chave mapeia para um set de paths SVG (Lucide-style)
const icons: Record<string, string> = {
  casa: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  tipologia: '<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
  fracoes: '<circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/>',
  patio: '<path d="M2 22h20"/><path d="M4 22V11l8-7 8 7v11"/><path d="M9 22v-7h6v7"/><circle cx="12" cy="13" r="1.5"/>',
  rio: '<path d="M2 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0 2 0 2 0"/><path d="M2 13c2-2 4-2 6 0s4 2 6 0 4-2 6 0 2 0 2 0"/>',
  documento: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="13" y2="17"/>',
  piscina: '<path d="M2 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0 2 0 2 0"/><path d="M2 13c2-2 4-2 6 0s4 2 6 0 4-2 6 0 2 0 2 0"/><path d="M2 8c2-2 4-2 6 0s4 2 6 0 4-2 6 0 2 0 2 0"/>',
  gourmet: '<path d="M8 4v6a4 4 0 0 0 8 0V4"/><path d="M12 14v8"/><path d="M8 22h8"/>',
  festas: '<circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/>',
  garagem: '<path d="M5 17h14M5 17a2 2 0 0 1-2-2v-3l2-5h14l2 5v3a2 2 0 0 1-2 2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/>',
  pin: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  elevador: '<rect x="8" y="3" width="8" height="18" rx="1"/><path d="M12 7v6M9 10l3 3 3-3"/>',
  preco: '<circle cx="12" cy="12" r="3"/><path d="M12 1v6M5 12H1M23 12h-4M16 8l3-3M5 19l3-3M19 19l-3-3M8 5L5 8"/>',
  edificio: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18"/>',
  check: '<circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/>',
  chave: '<path d="M3 12h18M12 3v18"/>',
  escada: '<path d="M4 20L20 4M4 14l10-10M4 8l4-4"/>',
  construcao: '<rect x="3" y="6" width="18" height="14" rx="1"/><path d="M3 10h18"/>',
};

function iconPath(key: string) {
  return icons[key] ?? icons.casa;
}
---

<div class="caracteristicas">
  {items.map((it) => (
    <div class="carac-item">
      <svg class="carac-icon" viewBox="0 0 24 24" set:html={iconPath(it.icon)} />
      <span class="carac-label">{it.label}</span>
    </div>
  ))}
</div>

<style>
  .caracteristicas {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px 40px;
    margin: 32px 0;
  }
  .carac-item {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .carac-icon {
    width: 32px; height: 32px;
    color: var(--telha);
    stroke: currentColor;
    fill: none;
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }
  .carac-label {
    font-size: 15px;
    color: var(--preto);
    font-weight: 500;
    line-height: 1.3;
  }
  @media (max-width: 900px) {
    .caracteristicas { grid-template-columns: 1fr 1fr; gap: 20px; }
  }
</style>
