---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "SINURBE — Habitar Lisboa",
  description = "Promoção imobiliária em bairros históricos de Lisboa. Empreendimentos próprios em edifícios pombalinos, gaioleiros e de placa. Av. da Liberdade 224, 2º.",
  image = "/og-image.jpg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const themeColor = "#b8442e";
---
<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site).toString()} />
  <meta property="og:locale" content="pt_PT" />
  <meta property="og:site_name" content="SINURBE" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

  <!-- Favicon (multi-tamanho gerado a partir do logo 01A) -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content={themeColor} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter+Tight:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@1,400;1,600;1,700&display=swap"
    rel="stylesheet"
  />

  <slot name="head" />

  <!-- Schema.org — RealEstateAgent -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "RealEstateAgent",
    "name": "SINURBE",
    "alternateName": "Síncope Urbana",
    "description": "Promoção imobiliária premium em Lisboa.",
    "url": "https://sinurbe.pt",
    "logo": "https://sinurbe.pt/favicon.svg",
    "telephone": "+351924184141",
    "email": "comercial@sinurbe.pt",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Av. Liberdade 224, 2º",
      "postalCode": "1250-148",
      "addressLocality": "Lisboa",
      "addressCountry": "PT"
    },
    "sameAs": [
      "https://instagram.com/sinurbe.pt",
      "https://facebook.com/sinurbe.pt",
      "https://x.com/Sinurbept",
      "https://youtube.com/@SinurbePortugal",
      "https://linkedin.com/company/sinurbe-pt"
    ]
  })} />
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  /* Importa tokens da marca (cores, tipografia, helpers) */
  @import "../styles/tokens.css";
</style>
